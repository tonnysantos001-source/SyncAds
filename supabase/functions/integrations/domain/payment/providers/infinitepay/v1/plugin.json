{
  "name": "InfinitePay",
  "slug": "infinitepay",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://www.infinitepay.io/blog/wp-content/uploads/2022/03/Infinitepay-Logo-1.svg",
  "description": "Gateway de pagamentos brasileiro da CloudWalk. Gere links de pagamento com Pix e Cartão de Crédito em até 12x via Checkout Integrado.",
  "status": "active",
  "configFields": [
    {
      "name": "handle",
      "label": "InfiniteTag (Handle)",
      "type": "text",
      "required": true,
      "placeholder": "minha_loja (sem o $)"
    },
    {
      "name": "clientId",
      "label": "Client ID",
      "type": "text",
      "required": true,
      "placeholder": "Obtido em Configurações > Credenciais"
    },
    {
      "name": "clientSecret",
      "label": "Client Secret",
      "type": "password",
      "required": true,
      "placeholder": "Obtido em Configurações > Credenciais"
    }
  ],
  "paymentMethods": ["credit_card", "pix"],
  "webhookSupport": true,
  "sandboxSupport": false,
  "apiDocsUrl": "https://www.infinitepay.io/desenvolvedores",
