      "placeholder": "Ex: sec_key_..."
    }
  ],
  "capabilities": {
    "supportsPix": false,
    "supportsCreditCard": true,
    "supportsBoleto": false,
    "supportsSubscription": false,
    "supportsSplit": false,
    "supportsRefund": true,
    "supportsWebhook": true
  }
