{
  "name": "Alphacash",
  "slug": "alphacash",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://alphacash.com.br/logo.png",
  "description": "Gateway brasileiro Alphacash focado em transações seguras de Pix, Boleto e Cartão com altos índices de aprovação.",
  "status": "active",
  "configFields": [
    {
      "name": "apiKey",
      "label": "API Key",
      "type": "password",
      "required": true,
      "placeholder": "Chave API Key fornecida pelo painel da Alphacash"
    },
    {
      "name": "secretKey",
      "label": "Secret Key",
      "type": "password",
      "required": true,
      "placeholder": "Assinatura ou chave secreta adicional"
    },
    {
      "name": "isTestMode",
      "label": "Modo Sandbox",
      "type": "checkbox",
      "required": false
    }
  ],
  "paymentMethods": ["credit_card", "pix", "boleto"],
  "webhookSupport": true,
  "sandboxSupport": true,
  "apiDocsUrl": "https://alphacash.com.br",
  "supportEmail": "suporte@alphacash.com.br"
}
