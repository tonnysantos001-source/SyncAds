{
  "name": "Getnet",
  "slug": "getnet",
  "version": "v1",
  "category": "payment",
  "logoUrl": "",
  "description": "Integração oficial do Getnet para processamento de pagamentos.",
  "status": "active",
  "configFields": [
    {
      "name": "clientId",
      "label": "Client ID",
      "type": "text",
      "required": true,
      "placeholder": "Ex: 9eb9-4081-9b16-52c676451e03"
    },
    {
      "name": "clientSecret",
      "label": "Client Secret",
      "type": "password",
      "required": true,
      "placeholder": "Ex: a1b2c3d4..."
    },
    {
      "name": "sellerId",
      "label": "Seller ID",
      "type": "text",
      "required": true,
      "placeholder": "Ex: 12345678-1234-1234-1234-123456789012"
    }
  ],
  "capabilities": {
    "supportsPix": true,
    "supportsCreditCard": true,
    "supportsBoleto": true,
    "supportsSubscription": false,
    "supportsSplit": false,
    "supportsRefund": true,
    "supportsWebhook": true
  }
}
