{
  "name": "Diasmarketplace",
  "slug": "diasmarketplace",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://diasmarketplace.com.br/logo.png",
  "description": "Gateway brasileiro focado em processamento de Pix, Cartão de Crédito e Boleto com alta estabilidade e checkout transparente.",
  "status": "active",
  "configFields": [
    {
      "name": "apiKey",
      "label": "API Key",
      "type": "password",
      "required": true,
      "placeholder": "Chave de API obtida no painel Dias Marketplace"
    },
    {
      "name": "storeId",
      "label": "Store ID",
      "type": "text",
      "required": true,
      "placeholder": "Identificador da loja"
    },
    {
      "name": "isTestMode",
      "label": "Modo Sandbox",
      "type": "checkbox",
      "required": false
    }
  ],
  "paymentMethods": ["credit_card", "pix", "boleto"],
  "webhookSupport": true,
  "sandboxSupport": true,
  "apiDocsUrl": "https://diasmarketplace.com.br",
  "supportEmail": "suporte@diasmarketplace.com.br"
}
