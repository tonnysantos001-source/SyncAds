{
  "name": "SafetyPay",
  "slug": "safetypay",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://safetypay.com/logo.png",
  "description": "Gateway internacional SafetyPay focado em transferências bancárias seguras em tempo real e pagamentos via lotéricas.",
  "status": "active",
  "configFields": [
    {
      "name": "apiKey",
      "label": "API Key",
      "type": "password",
      "required": true,
      "placeholder": "Chave pública X-API-Key fornecida pela SafetyPay"
    },
    {
      "name": "signatureKey",
      "label": "Signature Key / Secret",
      "type": "password",
      "required": true,
      "placeholder": "Chave para assinatura / validação criptográfica"
    },
    {
      "name": "isTestMode",
      "label": "Modo Sandbox (Test)",
      "type": "checkbox",
      "required": false
    }
  ],
  "paymentMethods": ["pix", "debit_card"],
  "webhookSupport": true,
  "sandboxSupport": true,
  "apiDocsUrl": "https://safetypay.com",
  "supportEmail": "suporte@safetypay.com"
}
