{
  "name": "Cielo",
  "slug": "cielo",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://developercielo.github.io/manual/images/cielo-logo.png",
  "description": "Integração oficial de Cielo e-commerce para processamento de pagamentos.",
  "status": "active",
  "configFields": [
    {
      "name": "merchantId",
      "label": "Merchant ID Cielo",
      "type": "text",
      "required": true,
      "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
    },
    {
      "name": "merchantKey",
      "label": "Merchant Key Cielo",
      "type": "password",
      "required": true,
      "placeholder": "Chave de 40 caracteres"
    }
  ],
  "capabilities": {
    "supportsPix": true,
    "supportsCreditCard": true,
    "supportsBoleto": true,
    "supportsSubscription": true,
    "supportsSplit": true,
    "supportsRefund": true,
    "supportsWebhook": true
  }
}