{
  "name": "Braza Pay",
  "slug": "brazapay",
  "version": "v1",
  "category": "payment",
  "logoUrl": "https://cdn-icons-png.flaticon.com/512/5968/5968292.png",
  "description": "Integração oficial da Braza Pay para processamento de Pix, Cartão e Boleto.",
  "status": "active",
  "configFields": [
    {
