      "placeholder": "ID da Conta Braza Pay"
    }
  ],
  "capabilities": {
    "supportsPix": true,
    "supportsCreditCard": true,
    "supportsBoleto": true,
    "supportsSubscription": false,
    "supportsSplit": false,
    "supportsRefund": true,
    "supportsWebhook": true
